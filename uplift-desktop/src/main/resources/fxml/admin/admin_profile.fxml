<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.uplift.desktop.controller.admin.AdminProfileController"
            styleClass="content-root">

    <children>
        <VBox spacing="16" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- Page title -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Profile"
                       styleClass="page-title"/>
            </HBox>

            <!-- Main Card -->
            <HBox spacing="16">
                <!-- Left: Profile summary card -->
                <VBox spacing="14" styleClass="card" prefWidth="340">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <StackPane style="-fx-background-color: white; -fx-background-radius: 50; -fx-padding: 10;">
                            <ImageView fitHeight="34" fitWidth="34" preserveRatio="true">
                                <image>
                                    <Image url="@/img/profile.png"/>
                                </image>
                            </ImageView>
                        </StackPane>

                        <VBox spacing="2">
                            <Label fx:id="lblNameBig"
                                   text="Admin Name"
                                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                            <Label fx:id="lblRoleBig"
                                   text="ADMIN"
                                   style="-fx-text-fill: #6b7280;"/>
                        </VBox>
                    </HBox>

                    <Separator/>

                    <VBox spacing="8">
                        <Label text="Email" styleClass="field-label"/>
                        <Label fx:id="lblEmailSmall" text="email@example.com"
                               style="-fx-font-size: 13px; -fx-text-fill: #111827;"/>
                    </VBox>

                    <VBox spacing="8">
                        <Label text="Account Status" styleClass="field-label"/>
                        <Label fx:id="lblActive"
                               text="Active"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #16a34a;"/>
                    </VBox>

                    <Pane VBox.vgrow="ALWAYS"/>

                    <Label text="Tip: Keep your details updated for a smoother ride experience."
                           wrapText="true"
                           style="-fx-text-fill: #6b7280; -fx-font-size: 12px;"/>
                </VBox>

                <!-- Right: Edit section (UI-only for now) -->
                <VBox spacing="14" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="Account Details"
                           styleClass="section-title"/>

                    <GridPane hgap="12" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="130" halignment="RIGHT"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <children>
                            <Label text="Full Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtFullName" promptText="Full name"
                                       GridPane.rowIndex="0" GridPane.columnIndex="1"
                                       styleClass="text-input-field"/>

                            <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtEmail" editable="false"
                                       GridPane.rowIndex="1" GridPane.columnIndex="1"
                                       styleClass="text-input-field"/>

                            <Label text="Phone:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtPhone" promptText="Optional"
                                       GridPane.rowIndex="2" GridPane.columnIndex="1"
                                       styleClass="text-input-field"/>

                            <!-- after Phone row -->
                            <Label text="Address:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtAddress" promptText="Street, City, Country"
                                       GridPane.rowIndex="3" GridPane.columnIndex="1"
                                       styleClass="text-input-field"/>

                            <!-- shift Role row down by 1 -->
                            <Label text="Role:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtRole" editable="false"
                                       GridPane.rowIndex="4" GridPane.columnIndex="1"
                                       styleClass="text-input-field"/>

                        </children>
                    </GridPane>

                    <Separator/>

                    <Label text="Change Password"
                           styleClass="section-title"/>

                    <VBox spacing="10" styleClass="form-container">
                        <PasswordField fx:id="txtCurrentPassword"
                                       promptText="Current password"
                                       styleClass="text-input-field"/>
                        <PasswordField fx:id="txtNewPassword"
                                       promptText="New password"
                                       styleClass="text-input-field"/>
                        <PasswordField fx:id="txtConfirmPassword"
                                       promptText="Confirm new password"
                                       styleClass="text-input-field"/>
                    </VBox>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="Save Changes"
                                fx:id="btnSave"
                                onAction="#handleSave"
                                styleClass="primary-button"/>
                        <Button text="Reset"
                                fx:id="btnReset"
                                onAction="#handleReset"
                                styleClass="secondary-button"/>
                    </HBox>

                    <Label fx:id="lblStatus"
                           text=""
                           style="-fx-text-fill: #6b7280;"/>
                </VBox>
            </HBox>
        </VBox>
    </children>
</AnchorPane>
