<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="rootPane"
            styleClass="root-background"
            stylesheets="@/css/theme.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.uplift.desktop.controller.OtpVerificationController">

    <center>
        <HBox prefHeight="580.0" prefWidth="980.0" spacing="0">

            <!-- LEFT: Hero panel (same look as others) -->
            <StackPane prefWidth="500.0" styleClass="hero-pane">
                <children>
                    <VBox alignment="CENTER" spacing="20.0">
                        <padding>
                            <Insets bottom="40" left="40" right="40" top="40" />
                        </padding>

                        <ImageView fitHeight="130" fitWidth="130" preserveRatio="true">
                            <image>
                                <Image url="@/img/uplift_logo.png" />
                            </image>
                        </ImageView>

                        <Label styleClass="hero-welcome" text="Email Verification" />
                        <Label styleClass="hero-title" text="Secure Your Account" />

                        <Label maxWidth="260"
                               styleClass="hero-subtitle"
                               text="We’ve sent a one-time verification code to your email. Enter it on the right to complete this step."
                               textAlignment="JUSTIFY"
                               wrapText="true">
                            <font>
                                <Font size="10.0" />
                            </font>
                        </Label>
                    </VBox>
                </children>
            </StackPane>

            <!-- RIGHT: OTP card -->
            <StackPane styleClass="login-pane" HBox.hgrow="ALWAYS">
                <children>
                    <VBox alignment="TOP_CENTER" spacing="18.0" styleClass="login-card">
                        <padding>
                            <Insets bottom="32" left="40" right="40" top="32" />
                        </padding>

                        <!-- Brand -->
                        <VBox alignment="CENTER" spacing="6.0">
                            <ImageView fitHeight="60" fitWidth="60" preserveRatio="true">
                                <image>
                                    <Image url="@/img/uplift_logo_c.png" />
                                </image>
                            </ImageView>
                            <Label styleClass="brand-title" text="UpLift" />
                            <Label styleClass="brand-subtitle" text="Two-Step Verification" />
                        </VBox>

                        <!-- Header -->
                        <VBox alignment="CENTER" spacing="4.0">
                            <Label fx:id="titleLabel"
                                   styleClass="login-title"
                                   text="Verify Your Email" />
                            <Label fx:id="subtitleLabel"
                                   styleClass="login-subtitle"
                                   text="Enter the 6-digit code we sent to your email." />
                            <Label fx:id="emailLabel"
                                   styleClass="footer-text"
                                   text="email@example.com" />
                        </VBox>

                        <!-- OTP field -->
                        <VBox alignment="TOP_LEFT" spacing="10.0" styleClass="form-container">
                            <Label styleClass="field-label" text="Verification Code" />
                            <TextField fx:id="otpField"
                                       promptText="Enter 6-digit code"
                                       styleClass="text-input-field" />
                        </VBox>

                        <!-- Verify button -->
                        <Button fx:id="verifyButton"
                                maxWidth="Infinity"
                                onAction="#handleVerifyOtp"
                                styleClass="primary-button"
                                text="Verify" />

                        <!-- Footer: Resend & Back -->
                        <HBox alignment="CENTER" spacing="10.0">
                            <Hyperlink fx:id="resendLink"
                                       onAction="#handleResendOtp"
                                       text="Resend code" />
                            <Label text="|" />
                            <Hyperlink fx:id="backToLoginLink"
                                       onAction="#handleBackToLogin"
                                       text="Back to login" />
                        </HBox>

                    </VBox>
                </children>
            </StackPane>

        </HBox>
    </center>
</BorderPane>
