<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="rootPane"
            styleClass="root-background"
            stylesheets="@/css/theme.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.uplift.desktop.controller.ResetPasswordController">

    <center>
        <HBox prefHeight="580.0" prefWidth="980.0" spacing="0">

            <StackPane prefWidth="500.0" styleClass="hero-pane">
                <children>
                    <VBox alignment="CENTER" spacing="20.0">
                        <padding>
                            <Insets bottom="40" left="40" right="40" top="40" />
                        </padding>

                        <ImageView fitHeight="130" fitWidth="130" preserveRatio="true">
                            <image>
                                <Image url="@/img/uplift_logo.png" />
                            </image>
                        </ImageView>

                        <Label styleClass="hero-welcome" text="Set New Password" />
                        <Label styleClass="hero-title" text="You're Almost Done" />
                    </VBox>
                </children>
            </StackPane>

            <StackPane styleClass="login-pane" HBox.hgrow="ALWAYS">
                <children>
                    <VBox alignment="TOP_CENTER" spacing="18.0" styleClass="login-card">
                        <padding>
                            <Insets bottom="32" left="40" right="40" top="32" />
                        </padding>

                        <VBox alignment="CENTER" spacing="6.0">
                            <ImageView fitHeight="60" fitWidth="60" preserveRatio="true">
                                <image>
                                    <Image url="@/img/uplift_logo_c.png" />
                                </image>
                            </ImageView>
                            <Label styleClass="brand-title" text="UpLift" />
                            <Label styleClass="brand-subtitle" text="Reset Password" />
                        </VBox>

                        <VBox alignment="CENTER" spacing="4.0">
                            <Label styleClass="login-title" text="Choose a new password" />
                            <Label fx:id="emailLabel" styleClass="footer-text" text="email@example.com" />
                        </VBox>

                        <VBox alignment="TOP_LEFT" spacing="10.0" styleClass="form-container">
                            <Label styleClass="field-label" text="New Password" />
                            <PasswordField fx:id="newPasswordField" promptText="••••••••" styleClass="text-input-field" />

                            <Label styleClass="field-label" text="Confirm Password" />
                            <PasswordField fx:id="confirmPasswordField" promptText="••••••••" styleClass="text-input-field" />
                        </VBox>

                        <Button maxWidth="Infinity"
                                onAction="#handleChangePassword"
                                styleClass="primary-button"
                                text="Change Password" />

                        <Hyperlink onAction="#handleBackToLogin" text="Back to login" />

                    </VBox>
                </children>
            </StackPane>

        </HBox>
    </center>
</BorderPane>
