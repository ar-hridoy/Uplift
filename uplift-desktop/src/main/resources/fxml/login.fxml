<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="rootPane"
            styleClass="root-background"
            stylesheets="@/css/theme.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.uplift.desktop.controller.LoginController">

    <!-- Non-node objects -->
    <fx:define>
        <ToggleGroup fx:id="userRoleToggleGroup" />
    </fx:define>

    <center>
        <HBox prefHeight="580.0" prefWidth="980.0" spacing="0">

            <!-- LEFT: Hero panel -->
            <StackPane prefWidth="500.0" styleClass="hero-pane">
                <children>
                    <VBox alignment="CENTER" spacing="20.0">
                        <padding>
                            <Insets bottom="40" left="40" right="40" top="40" />
                        </padding>

                        <ImageView fitHeight="130" fitWidth="130" preserveRatio="true">
                            <image>
                                <Image url="@/img/uplift_logo.png" />
                            </image>
                        </ImageView>

                        <Label styleClass="hero-welcome" text="Welcome to" />

                        <Label styleClass="hero-title" text="UpLift" />

                        <Label maxWidth="260" styleClass="hero-subtitle" text="Providing safe and reliable ride-sharing with comfort and trust. Join our growing community of riders and passengers who rely on us every day." textAlignment="JUSTIFY" wrapText="true">
                     <font>
                        <Font size="10.0" />
                     </font></Label>

                        <VBox alignment="TOP_LEFT" spacing="10.0">
                            <Label styleClass="hero-point" text="🗸 Affordable shared rides" />
                            <Label styleClass="hero-point" text="🗸 Trusted riders &amp; passengers" />
                            <Label styleClass="hero-point" text="🗸 Real-time ride updates" />
                            <Label styleClass="hero-point" text="🗸 Seamless payments" />
                        </VBox>
                    </VBox>
                </children>
            </StackPane>

            <!-- RIGHT: Login card -->
            <StackPane styleClass="login-pane" HBox.hgrow="ALWAYS">
                <children>
                    <VBox alignment="TOP_CENTER" spacing="18.0" styleClass="login-card">
                        <padding>
                            <Insets bottom="32" left="40" right="40" top="32" />
                        </padding>

                        <!-- Brand on card -->
                        <VBox alignment="CENTER" spacing="6.0">
                            <ImageView fitHeight="60" fitWidth="60" preserveRatio="true">
                                <image>
                                    <Image url="@/img/uplift_logo_c.png" />
                                </image>
                            </ImageView>
                            <Label styleClass="brand-title" text="UpLift" />
                            <Label styleClass="brand-subtitle" text="Save on Every Ride" />
                        </VBox>

                        <!-- Card header -->
                        <VBox alignment="CENTER" spacing="4.0">
                            <Label styleClass="login-title" text="Welcome Back" />
                            <Label styleClass="login-subtitle" text="Sign in to continue your journey" />
                        </VBox>

                        <!-- Passenger / Rider toggle -->
                        <HBox alignment="CENTER" prefHeight="37.0" prefWidth="392.0" spacing="0" styleClass="role-toggle-container">

                            <RadioButton fx:id="passengerRadio" onAction="#onRoleToggle" prefWidth="200.0" selected="true" styleClass="role-toggle-left" text=" Passenger">
                        <toggleGroup>
                           <ToggleGroup fx:id="userRoleToggleGroup" />
                        </toggleGroup></RadioButton>

                            <RadioButton fx:id="riderRadio" onAction="#onRoleToggle" prefWidth="200.0" styleClass="role-toggle-right" text=" Rider" toggleGroup="$userRoleToggleGroup">
                        <font>
                           <Font name="System Bold" size="12.0" />
                        </font></RadioButton>
                        </HBox>

                        <!-- Form fields -->
                        <VBox alignment="TOP_LEFT" spacing="10.0" styleClass="form-container">

                            <Label styleClass="field-label" text="Email" />
                            <TextField fx:id="emailField" promptText="your@email.com" styleClass="text-input-field" />

                            <Label styleClass="field-label" text="Password" />
                            <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="text-input-field" />

                            <HBox alignment="CENTER_LEFT" spacing="6.0">
                                <CheckBox fx:id="rememberMeCheckBox" text="Remember me" />
                                <Pane HBox.hgrow="ALWAYS" />
                                <Hyperlink fx:id="forgotPasswordLink" onAction="#onForgotPassword" text="Forgot password?" />
                            </HBox>
                        </VBox>

                        <!-- Sign in button -->
                        <Button fx:id="signInButton" maxWidth="Infinity" onAction="#handleSignIn" styleClass="primary-button" text="Sign In" />

                        <!-- Footer -->
                        <HBox alignment="CENTER" spacing="4.0">
                            <Label styleClass="footer-text" text="Don't have an account?" />
                            <Hyperlink fx:id="signupLink" onAction="#openSignup" text="Sign up as Passenger" />
                        </HBox>
                    </VBox>
                </children>
            </StackPane>

        </HBox>
    </center>
</BorderPane>
