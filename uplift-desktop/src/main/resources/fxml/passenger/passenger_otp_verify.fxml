<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.uplift.desktop.controller.OtpVerificationController">

    <center>
        <VBox spacing="10" alignment="CENTER" style="-fx-padding: 20;">
            <children>
                <Label fx:id="titleLabel"
                       text="Verify"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <Label fx:id="subtitleLabel"
                       text="Enter the code sent to your email."/>

                <Label fx:id="emailLabel"
                       text="email@example.com"
                       style="-fx-text-fill: #555555;"/>

                <TextField fx:id="otpField" promptText="Enter 6 digit code"
                           maxWidth="200"/>

                <HBox spacing="10" alignment="CENTER">
                    <children>
                        <Button text="Verify"
                                onAction="#handleVerifyOtp"/>
                        <Button text="Back to Login"
                                onAction="#handleBackToLogin"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

</BorderPane>
