<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.uplift.desktop.controller.PassengerSignupController"
            fx:id="rootPane"
            styleClass="root-background"
            stylesheets="@/css/theme.css">

    <center>
        <HBox prefHeight="580.0" prefWidth="980.0" spacing="0">

            <!-- LEFT: SAME HERO PANEL AS LOGIN -->
            <StackPane prefWidth="500.0" styleClass="hero-pane">
                <children>
                    <VBox alignment="CENTER" spacing="20.0">
                        <padding>
                            <Insets bottom="40" left="40" right="40" top="40" />
                        </padding>

                        <ImageView fitHeight="130" fitWidth="130" preserveRatio="true">
                            <image>
                                <Image url="@/img/uplift_logo.png" />
                            </image>
                        </ImageView>

                        <Label styleClass="hero-welcome" text="Welcome to" />
                        <Label styleClass="hero-title" text="UpLift" />

                        <Label maxWidth="260"
                               styleClass="hero-subtitle"
                               text="Providing safe and reliable ride-sharing with comfort and trust. Join our growing community of riders and passengers who rely on us every day."
                               textAlignment="JUSTIFY"
                               wrapText="true">
                            <font>
                                <Font size="10.0" />
                            </font>
                        </Label>

                        <VBox alignment="TOP_LEFT" spacing="10.0">
                            <Label styleClass="hero-point" text="🗸 Affordable shared rides" />
                            <Label styleClass="hero-point" text="🗸 Trusted riders &amp; passengers" />
                            <Label styleClass="hero-point" text="🗸 Real-time ride updates" />
                            <Label styleClass="hero-point" text="🗸 Seamless payments" />
                        </VBox>
                    </VBox>
                </children>
            </StackPane>

            <!-- RIGHT: SIGN-UP CARD -->
            <StackPane styleClass="login-pane" HBox.hgrow="ALWAYS">
                <children>
                    <VBox alignment="TOP_CENTER" spacing="18.0" styleClass="login-card">
                        <padding>
                            <Insets bottom="32" left="40" right="40" top="32" />
                        </padding>

                        <!-- Brand on card -->
                        <VBox alignment="CENTER" spacing="6.0">
                            <ImageView fitHeight="60" fitWidth="60" preserveRatio="true">
                                <image>
                                    <Image url="@/img/uplift_logo_c.png" />
                                </image>
                            </ImageView>
                            <Label styleClass="brand-title" text="UpLift" />
                            <Label styleClass="brand-subtitle" text="Save on Every Ride" />
                        </VBox>

                        <!-- Card header -->
                        <VBox alignment="CENTER" spacing="4.0">
                            <Label styleClass="login-title" text="Passenger Sign Up" />
                            <Label styleClass="login-subtitle" text="Create your UpLift passenger account" />
                        </VBox>

                        <!-- FORM FIELDS -->
                        <VBox alignment="TOP_LEFT" spacing="10.0" styleClass="form-container">

                            <Label styleClass="field-label" text="Full Name" />
                            <TextField fx:id="fullNameField"
                                       promptText="Enter your full name"
                                       styleClass="text-input-field" />

                            <Label styleClass="field-label" text="Username" />
                            <TextField fx:id="usernameField"
                                       promptText="Choose a username"
                                       styleClass="text-input-field" />

                            <Label styleClass="field-label" text="Email" />
                            <TextField fx:id="emailField"
                                       promptText="your@email.com"
                                       styleClass="text-input-field" />

                            <Label styleClass="field-label" text="Password" />
                            <PasswordField fx:id="passwordField"
                                           promptText="Create a password"
                                           styleClass="text-input-field" />

                            <Label styleClass="field-label" text="Confirm Password" />
                            <PasswordField fx:id="confirmPasswordField"
                                           promptText="Re-enter password"
                                           styleClass="text-input-field" />
                        </VBox>

                        <!-- BUTTONS -->
                        <HBox alignment="CENTER" spacing="10.0">
                            <Button fx:id="backToLoginButton"
                                    text="Back to Login"
                                    onAction="#handleBackToLogin"
                                    styleClass="secondary-button" />

                            <Button fx:id="createAccountButton"
                                    text="Create Account"
                                    onAction="#handleCreateAccount"
                                    styleClass="primary-button"
                                    maxWidth="Infinity" />
                        </HBox>
                    </VBox>
                </children>
            </StackPane>

        </HBox>
    </center>
</BorderPane>
