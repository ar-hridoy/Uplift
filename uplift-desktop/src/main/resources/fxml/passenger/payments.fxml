<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.uplift.desktop.controller.passenger.PassengerPaymentsController">

    <children>
        <VBox spacing="16" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Payments" styleClass="page-title"/>

            <HBox spacing="16">
                <VBox styleClass="card">
                    <Label styleClass="card-title" text="Total Spent This Month"/>
                    <Label fx:id="lblTotalThisMonth" styleClass="card-value" text="৳0.00"/>
                </VBox>
                <VBox styleClass="card">
                    <Label styleClass="card-title" text="Last Payment"/>
                    <Label fx:id="lblLastPayment" styleClass="card-value" text="—"/>
                </VBox>
            </HBox>

            <Label styleClass="section-title" text="Payment History"/>
            <TableView fx:id="tblPayments" prefHeight="380">
                <columns>
                    <TableColumn fx:id="colDate"   prefWidth="160" text="Date"/>
                    <TableColumn fx:id="colRideId" prefWidth="100" text="Ride ID"/>
                    <TableColumn fx:id="colMethod" prefWidth="120" text="Method"/>
                    <TableColumn fx:id="colAmount" prefWidth="120" text="Amount"/>
                    <TableColumn fx:id="colStatus" prefWidth="120" text="Status"/>
                </columns>
            </TableView>
        </VBox>
    </children>
</AnchorPane>
