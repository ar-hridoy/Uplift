<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.uplift.desktop.controller.passenger.PassengerRequestRideController"
            styleClass="content-root">

    <children>
        <VBox spacing="16"
              AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- Title -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Request a Ride" styleClass="page-title"/>
                <Label text="• Choose Instant or Future"
                       style="-fx-text-fill:#6b7280; -fx-font-size:12;"/>
            </HBox>

            <!-- Two cards layout -->
            <HBox spacing="16" VBox.vgrow="ALWAYS">

                <!-- LEFT CARD -->
                <VBox spacing="14" styleClass="card request-card" prefWidth="520" minWidth="520">
                    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Ride Details" styleClass="section-title"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="pill-group">

                            <RadioButton fx:id="rbInstant" text="Instant" styleClass="pill-radio"/>
                            <RadioButton fx:id="rbFuture"  text="Future"  styleClass="pill-radio"/>

                        </HBox>
                    </HBox>

                    <GridPane hgap="12" vgap="12">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="120"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="Pickup:" styleClass="form-label"
                               GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtFrom"
                                   promptText="Pickup location"
                                   styleClass="text-input-field"
                                   prefHeight="38"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Destination:" styleClass="form-label"
                               GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtTo"
                                   promptText="Where to?"
                                   styleClass="text-input-field"
                                   prefHeight="38"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Seats:" styleClass="form-label"
                               GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Spinner fx:id="spSeats"
                                 prefHeight="38"
                                 GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Note:" styleClass="form-label"
                               GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <TextArea fx:id="txtNote"
                                  promptText="Optional note for rider..."
                                  prefRowCount="3"
                                  wrapText="true"
                                  GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    </GridPane>

                    <!-- Future (Hidden unless Future selected) -->
                    <VBox fx:id="futureBox" spacing="10" visible="false" managed="false">
                        <Separator/>
                        <Label text="Schedule (Future Ride)" styleClass="section-title"/>

                        <GridPane hgap="12" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints prefWidth="120"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>

                            <Label text="Date:" styleClass="form-label"
                                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <DatePicker fx:id="dpDate"
                                        prefHeight="38"
                                        GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Time:" styleClass="form-label"
                                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtTime"
                                       promptText="HH:mm (e.g. 18:30)"
                                       styleClass="text-input-field"
                                       prefHeight="38"
                                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        </GridPane>
                    </VBox>

                    <Separator/>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="Reset" onAction="#handleReset" styleClass="secondary-button"/>
                        <Button text="Submit Request" onAction="#handleSubmit" styleClass="primary-button"
                                prefHeight="40"/>
                    </HBox>
                </VBox>

                <!-- RIGHT CARD -->
                <VBox spacing="14" styleClass="card request-card" HBox.hgrow="ALWAYS">
                    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>

                    <Label text="Preview" styleClass="section-title"/>

                    <VBox spacing="8" styleClass="preview-box">
                        <Label fx:id="lblPreview"
                               text="Fill the form to preview your request."
                               style="-fx-text-fill:#4b5563; -fx-font-size:13;"/>
                    </VBox>

                    <Separator/>

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Estimated Fare" styleClass="section-title"/>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblFare"
                               text="৳0"
                               style="-fx-font-size:28; -fx-font-weight:800;"/>
                    </HBox>

                    <Label text="Tip: Future rides allow riders to accept early."
                           style="-fx-text-fill:#6b7280; -fx-font-size:12;"/>

                    <Pane VBox.vgrow="ALWAYS"/>

                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="info-strip">
                        <Label text="ℹ" style="-fx-font-size:16;"/>
                        <Label text="Instant rides are sent immediately. Future rides show schedule fields."
                               style="-fx-text-fill:#374151;"/>
                    </HBox>
                </VBox>

            </HBox>
        </VBox>
    </children>
</AnchorPane>
